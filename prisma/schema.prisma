generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// ── Auth (NextAuth) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  player   Player?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Game ─────────────────────────────────────────────────────────

model GameWorld {
  id               String   @id @default("world")
  currentTick      Int      @default(0)
  tickRate         Int      @default(5000)
  lastTickAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt
  startingSystemId String?
}

model Region {
  id              String       @id @default(cuid())
  name            String       @unique
  dominantEconomy String       @default("extraction") // Most common economy type in the region
  x               Float
  y               Float
  systems         StarSystem[]
  events          GameEvent[]
}

model Player {
  id        String   @id @default(cuid())
  userId    String   @unique
  credits   Float    @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ships              Ship[]
  convoys            Convoy[]
  tradeMissions      TradeMission[]
  missions           Mission[]
  notifications      PlayerNotification[]
  npcVisits          NpcVisit[]
  factionReputations PlayerFactionReputation[]
}

model Ship {
  id                  String   @id @default(cuid())
  playerId            String
  name                String   @default("Starter Ship")
  shipType            String   @default("shuttle")
  fuel                Float    @default(100)
  maxFuel             Float    @default(100)
  cargoMax            Int      @default(50)
  speed               Int      @default(5)
  hullMax             Int      @default(40)
  hullCurrent         Int      @default(40)
  shieldMax           Int      @default(10)
  shieldCurrent       Int      @default(10)
  firepower           Int      @default(2)
  evasion             Int      @default(6)
  stealth             Int      @default(3)
  sensors             Int      @default(4)
  crewCapacity        Int      @default(2)
  disabled            Boolean  @default(false)
  status              String   @default("docked")
  systemId            String
  destinationSystemId String?
  departureTick       Int?
  arrivalTick         Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  player       Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  system       StarSystem        @relation("ShipCurrentSystem", fields: [systemId], references: [id])
  destination  StarSystem?       @relation("ShipDestination", fields: [destinationSystemId], references: [id])
  cargo        CargoItem[]
  upgradeSlots ShipUpgradeSlot[]
  convoyMember ConvoyMember?
  missions     Mission[]
  battles      Battle[]

  @@index([playerId])
}

model ShipUpgradeSlot {
  id         String  @id @default(cuid())
  shipId     String
  slotType   String // "engine" | "cargo" | "defence" | "systems"
  slotIndex  Int // 0-based index within slotType
  moduleId   String? // null = empty slot
  moduleTier Int? // null = empty slot

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@unique([shipId, slotType, slotIndex])
  @@index([shipId])
}

model Convoy {
  id                  String   @id @default(cuid())
  playerId            String
  name                String?
  systemId            String
  status              String   @default("docked") // "docked" | "in_transit"
  destinationSystemId String?
  departureTick       Int?
  arrivalTick         Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  player      Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  system      StarSystem     @relation("ConvoyCurrentSystem", fields: [systemId], references: [id])
  destination StarSystem?    @relation("ConvoyDestination", fields: [destinationSystemId], references: [id])
  members     ConvoyMember[]

  @@index([playerId])
}

model ConvoyMember {
  id       String @id @default(cuid())
  convoyId String
  shipId   String @unique // a ship can only be in one convoy

  convoy Convoy @relation(fields: [convoyId], references: [id], onDelete: Cascade)
  ship   Ship   @relation(fields: [shipId], references: [id], onDelete: Cascade)
}

model CargoItem {
  id       String @id @default(cuid())
  shipId   String
  goodId   String
  quantity Int

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Cascade)
  good Good @relation(fields: [goodId], references: [id])

  @@unique([shipId, goodId])
}

model StarSystem {
  id               String  @id @default(cuid())
  name             String  @unique
  economyType      String
  x                Float
  y                Float
  description      String  @default("")
  regionId         String
  factionId        String?
  isGateway        Boolean @default(false)

  // ── Physical substrate ──
  sunClass         String  @default("yellow")  // SunClass; real value written at seed time
  population       Float   @default(0)          // abstract magnitude
  popCap           Float   @default(0)          // maximum sustainable population
  unrest           Float   @default(0)          // 0…1 — integral of demand-weighted dissatisfaction
  bodyDanger       Float   @default(0)  // Σ body-archetype danger baselines
  availableSpace   Float @default(0)   // SPACE_PER_SIZE × Σ size
  generalSpace     Float @default(0)   // fungible (non-deposit) space
  habitableSpace   Float @default(0)   // habitable fraction of general — caps population centres
  slotGas          Float @default(0)   // extractor-slot caps (one per resource)
  slotMinerals     Float @default(0)
  slotOre          Float @default(0)
  slotBiomass      Float @default(0)
  slotArable       Float @default(0)
  slotWater        Float @default(0)
  slotRadioactive  Float @default(0)
  yieldGas         Float @default(1)   // effective quality multipliers (one per resource)
  yieldMinerals    Float @default(1)
  yieldOre         Float @default(1)
  yieldBiomass     Float @default(1)
  yieldArable      Float @default(1)
  yieldWater       Float @default(1)
  yieldRadioactive Float @default(1)

  region            Region             @relation(fields: [regionId], references: [id])
  faction           Faction?           @relation("FactionTerritory", fields: [factionId], references: [id])
  factionHomeworld  Faction?           @relation("FactionHomeworld")
  station           Station?
  traits            SystemTrait[]
  bodies            SystemBody[]
  buildings         SystemBuilding[]
  ships             Ship[]             @relation("ShipCurrentSystem")
  incomingShips     Ship[]             @relation("ShipDestination")
  convoys           Convoy[]           @relation("ConvoyCurrentSystem")
  incomingConvoys   Convoy[]           @relation("ConvoyDestination")
  connectionsFrom   SystemConnection[] @relation("FromSystem")
  connectionsTo     SystemConnection[] @relation("ToSystem")
  events            GameEvent[]
  priceHistory      PriceHistory?
  missionsPosted    TradeMission[]     @relation("MissionBoard")
  missionsTargeting TradeMission[]     @relation("MissionDest")
  missions          Mission[]          @relation("MissionSystem")
  missionTargets    Mission[]          @relation("MissionTarget")
  battles           Battle[]
  tradeFlowsFrom    TradeFlow[]        @relation("TradeFlowsFrom")
  tradeFlowsTo      TradeFlow[]        @relation("TradeFlowsTo")

  @@index([regionId])
  @@index([factionId])
  @@index([x, y])
}

model SystemBody {
  id                String  @id @default(cuid())
  systemId          String
  bodyType          String  // BodyArchetypeId
  habitable         Boolean @default(false)
  size              Float   @default(1)
  generalSpace     Float @default(0)   // this body's general space
  habitableSpace   Float @default(0)   // this body's habitable space
  slotGas          Float @default(0)   // per-body slot counts (one per resource)
  slotMinerals     Float @default(0)
  slotOre          Float @default(0)
  slotBiomass      Float @default(0)
  slotArable       Float @default(0)
  slotWater        Float @default(0)
  slotRadioactive  Float @default(0)
  qualGas          Float @default(0)   // per-body quality multipliers (0 = no deposit)
  qualMinerals     Float @default(0)
  qualOre          Float @default(0)
  qualBiomass      Float @default(0)
  qualArable       Float @default(0)
  qualWater        Float @default(0)
  qualRadioactive  Float @default(0)

  system StarSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([systemId])
}

model SystemBuilding {
  id           String @id @default(cuid())
  systemId     String
  buildingType String // production type id (== output good id) | "housing"
  count        Float  @default(0)

  system StarSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, buildingType])
  @@index([systemId])
}

model SystemTrait {
  id       String @id @default(cuid())
  systemId String
  traitId  String // TraitId: asteroid_belt, habitable_world, etc.
  quality  Int // QualityTier: 1 (Marginal), 2 (Solid), 3 (Exceptional)

  system StarSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, traitId])
  @@index([systemId])
}

model SystemConnection {
  id           String @id @default(cuid())
  fromSystemId String
  toSystemId   String
  fuelCost     Float  @default(10)

  fromSystem StarSystem @relation("FromSystem", fields: [fromSystemId], references: [id])
  toSystem   StarSystem @relation("ToSystem", fields: [toSystemId], references: [id])

  @@unique([fromSystemId, toSystemId])
}

model Station {
  id       String @id @default(cuid())
  name     String
  systemId String @unique

  system  StarSystem      @relation(fields: [systemId], references: [id])
  markets StationMarket[]
  trades  TradeHistory[]
}

model Good {
  id           String @id @default(cuid())
  name         String @unique
  description  String @default("")
  basePrice    Float
  tier         Int    @default(0)
  volume       Int    @default(1)
  mass         Float  @default(1.0)
  volatility   Float  @default(1.0)
  hazard       String @default("none")
  priceFloor   Float  @default(0.2)
  priceCeiling Float  @default(5.0)

  cargoItems    CargoItem[]
  markets       StationMarket[]
  trades        TradeHistory[]
  tradeMissions TradeMission[]
}

// Stock-based economy: a single `stock` axis replaced the legacy
// `supply` + `demand` columns. This was applied via `prisma db push` (no
// migration file), which is fine for the dev workflow where the DB is reseeded
// (`npx prisma db seed`) after a schema change.
//
// MIGRATION NOTE: any environment with live data (staging/prod) MUST run a real
// migration that derives `stock` from the old `supply`/`demand` values BEFORE
// those columns are dropped — `db push` would discard player-facing market state.
model StationMarket {
  id        String   @id @default(cuid())
  stationId String
  goodId    String
  stock      Float
  anchorMult Float    @default(1)
  /** Per-capita-need × population (floored) — the days-of-supply denominator. Static while population is static; seed-written. */
  demandRate Float    @default(1)
  /** Infrastructure storage capacity for this good from the system's built buildings. Used as the maxStock depth term in the per-market band. Seed-written from facilityStorageForGood. */
  storageCapacity Float @default(0)
  updatedAt  DateTime @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  good    Good    @relation(fields: [goodId], references: [id])

  @@unique([stationId, goodId])
}

model TradeHistory {
  id        String   @id @default(cuid())
  stationId String
  goodId    String
  price     Float
  quantity  Int
  type      String // "buy" or "sell"
  playerId  String?
  createdAt DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
  good    Good    @relation(fields: [goodId], references: [id])

  @@index([stationId])
}

model PriceHistory {
  id       String @id @default(cuid())
  systemId String @unique
  entries  String @default("[]") // JSON: { tick: number, prices: Record<goodId, price> }[]

  system StarSystem @relation(fields: [systemId], references: [id])
}

// ── Trade Flow ─────────────────────────────────────────────────

model TradeFlow {
  id           String @id @default(cuid())
  tick         Int
  fromSystemId String
  toSystemId   String
  goodId       String
  quantity     Int
  flowType     String @default("market") // "market" (diffusion) | "logistics" (directed)

  fromSystem StarSystem @relation("TradeFlowsFrom", fields: [fromSystemId], references: [id])
  toSystem   StarSystem @relation("TradeFlowsTo", fields: [toSystemId], references: [id])

  @@index([tick])
  @@index([fromSystemId, tick])
  @@index([toSystemId, tick])
  @@index([goodId, tick])
}

// ── Events ──────────────────────────────────────────────────────

model GameEvent {
  id             String  @id @default(cuid())
  type           String // Event definition key: "war", "plague", etc.
  phase          String // Current phase name: "tensions", "active", etc.
  systemId       String? // Target system (null for region-level events)
  regionId       String? // Target region
  startTick      Int // Tick when event was created
  phaseStartTick Int // Tick when current phase began
  phaseDuration  Int // Ticks until next phase transition
  severity       Float   @default(1.0) // Intensity multiplier (spread events are weaker)
  sourceEventId  String? // Parent event (for spread events)
  metadata       String  @default("{}") // JSON: event-specific data

  system        StarSystem?     @relation(fields: [systemId], references: [id])
  region        Region?         @relation(fields: [regionId], references: [id])
  sourceEvent   GameEvent?      @relation("EventSpread", fields: [sourceEventId], references: [id])
  spreadEvents  GameEvent[]     @relation("EventSpread")
  modifiers     EventModifier[]
  tradeMissions TradeMission[]
  missions      Mission[]

  @@index([type])
  @@index([systemId])
  @@index([regionId])
}

model EventModifier {
  id         String  @id @default(cuid())
  eventId    String
  domain     String // "economy", "navigation", "combat", "reputation"
  type       String // "anchor_shift", "rate_multiplier", "equilibrium_shift"
  targetType String // "system", "region"
  targetId   String? // systemId or regionId
  goodId     String? // Specific good key, or null for all goods
  parameter  String // "target_stock", "production_rate", "consumption_rate", "danger_level"
  value      Float // Modifier value

  event GameEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([domain, targetType, targetId])
  @@index([eventId])
}

// ── Trade Missions ──────────────────────────────────────────────

model TradeMission {
  id             String  @id @default(cuid())
  systemId       String // Board station (where mission appears)
  destinationId  String // Delivery target
  goodId         String
  quantity       Int
  reward         Int // Fixed CR payout
  deadlineTick   Int // Available missions expire here
  eventId        String? // Cascade-deletes with event
  factionId      String? // Owning faction (faction reputation)
  penaltyType    String  @default("none") // Future: "credits" | "reputation"
  penaltyValue   Int     @default(0)
  playerId       String? // null = available, set = accepted
  acceptedAtTick Int?
  createdAtTick  Int

  system      StarSystem @relation("MissionBoard", fields: [systemId], references: [id])
  destination StarSystem @relation("MissionDest", fields: [destinationId], references: [id])
  good        Good       @relation(fields: [goodId], references: [id])
  event       GameEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player      Player?    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  faction     Faction?   @relation(fields: [factionId], references: [id])

  @@index([systemId, playerId])
  @@index([playerId])
  @@index([deadlineTick])
  @@index([eventId])
  @@index([factionId])
}

// ── Operational Missions ────────────────────────────────────────

model Mission {
  id               String  @id @default(cuid())
  type             String // "patrol" | "survey" | "bounty"
  systemId         String // Where mission is posted
  targetSystemId   String // Where mission takes place
  reward           Int
  deadlineTick     Int
  durationTicks    Int? // Patrol/survey commitment time (null for bounty)
  enemyTier        String? // Bounty: "weak" | "moderate" | "strong"
  statRequirements String  @default("{}") // JSON: { firepower: 5 } etc.
  createdAtTick    Int
  eventId          String? // Source event (event-spawned missions)

  // State
  status          String  @default("available") // available | accepted | in_progress | completed | failed
  playerId        String?
  shipId          String?
  acceptedAtTick  Int?
  startedAtTick   Int? // When ship arrived and commitment began
  completedAtTick Int?

  // Relations
  system       StarSystem @relation("MissionSystem", fields: [systemId], references: [id])
  targetSystem StarSystem @relation("MissionTarget", fields: [targetSystemId], references: [id])
  player       Player?    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  ship         Ship?      @relation(fields: [shipId], references: [id], onDelete: SetNull)
  event        GameEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  battle       Battle?

  @@index([systemId, status])
  @@index([playerId])
  @@index([deadlineTick])
  @@index([targetSystemId, status])
  @@index([eventId])
}

// ── Battles ─────────────────────────────────────────────────────

model Battle {
  id        String  @id @default(cuid())
  type      String // "pirate_encounter" — later: "fleet_battle"
  systemId  String
  missionId String? @unique
  shipId    String?

  status String @default("active") // active | player_victory | player_defeat | player_retreat | enemy_retreat

  // Player side
  playerStrength        Float
  playerMorale          Float
  dangerLevel           Float? // Danger at battle creation for enemy scaling
  initialPlayerStrength Float? // Player strength at battle start for damage calc

  // Enemy side
  enemyStrength Float
  enemyMorale   Float
  enemyType     String // "pirates" — later: faction names
  enemyTier     String // "weak" | "moderate" | "strong"

  // Resolution
  roundsCompleted Int    @default(0)
  roundInterval   Int    @default(6)
  nextRoundTick   Int
  roundHistory    String @default("[]") // JSON: Array<RoundResult>

  createdAtTick  Int
  resolvedAtTick Int?

  // Relations
  system  StarSystem @relation(fields: [systemId], references: [id])
  mission Mission?   @relation(fields: [missionId], references: [id], onDelete: SetNull)
  ship    Ship?      @relation(fields: [shipId], references: [id], onDelete: SetNull)

  @@index([status, nextRoundTick])
  @@index([systemId])
  @@index([shipId])
}

// ── Notifications ──────────────────────────────────────────────

model PlayerNotification {
  id        String   @id @default(cuid())
  playerId  String
  type      String
  message   String
  refs      String   @default("{}")
  tick      Int
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([playerId, read])
}

model NpcVisit {
  id       String @id @default(cuid())
  playerId String
  npcType  String
  systemId String
  visits   Int    @default(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, npcType, systemId])
  @@index([playerId])
}

// ── Factions ───────────────────────────────────────────────────

model Faction {
  id             String @id @default(cuid())
  name           String @unique
  description    String @default("")
  governmentType String // GovernmentType union (validated at boundary)
  doctrine       String // Doctrine union (validated at boundary)
  homeworldId    String @unique // FK to StarSystem; one homeworld per faction
  color          String // Hex (with leading #) for territory rendering
  createdAtTick  Int

  homeworld     StarSystem                @relation("FactionHomeworld", fields: [homeworldId], references: [id])
  territory     StarSystem[]              @relation("FactionTerritory")
  tradeMissions TradeMission[]
  reputations   PlayerFactionReputation[]
  relationsAsA  FactionRelation[]         @relation("RelationFactionA")
  relationsAsB  FactionRelation[]         @relation("RelationFactionB")
  alliancesAsA  AlliancePact[]            @relation("AllianceFactionA")
  alliancesAsB  AlliancePact[]            @relation("AllianceFactionB")
}

/// Pair-wise relation score between two factions. The adapter layer enforces the
/// convention `factionAId < factionBId` so each unordered pair occupies one row.
model FactionRelation {
  id            String @id @default(cuid())
  factionAId    String
  factionBId    String
  score         Float  @default(0) // [-100, +100]
  historyJson   String @default("[]") // JSON ring buffer of recent drift drivers
  updatedAtTick Int    @default(0)

  factionA Faction @relation("RelationFactionA", fields: [factionAId], references: [id], onDelete: Cascade)
  factionB Faction @relation("RelationFactionB", fields: [factionBId], references: [id], onDelete: Cascade)

  // The composite @@unique already creates a B-tree whose leftmost column
  // serves factionAId-only lookups, so a separate @@index([factionAId]) would
  // be redundant. @@index([factionBId]) IS needed — it's not a prefix of the
  // unique index.
  @@unique([factionAId, factionBId])
  @@index([factionBId])
}

/// Active alliance between a pair of factions. One pact per pair at any time.
model AlliancePact {
  id                       String @id @default(cuid())
  factionAId               String
  factionBId               String
  formedAtTick             Int
  pendingDissolutionAtTick Int?

  factionA Faction @relation("AllianceFactionA", fields: [factionAId], references: [id], onDelete: Cascade)
  factionB Faction @relation("AllianceFactionB", fields: [factionBId], references: [id], onDelete: Cascade)

  // Same index reasoning as FactionRelation above.
  @@unique([factionAId, factionBId])
  @@index([factionBId])
}

/// Per-player, per-faction reputation score. Drives trade multipliers.
model PlayerFactionReputation {
  id                      String @id @default(cuid())
  playerId                String
  factionId               String
  score                   Float  @default(0) // [-100, +100]
  updatedAtTick           Int    @default(0)
  /// Reputation accrued so far in `updatedAtTick`. Reset on the first accrual of a new tick.
  currentTickGainThisTick Float  @default(0)

  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@unique([playerId, factionId])
  @@index([playerId])
  @@index([factionId])
}
